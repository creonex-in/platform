# Copy to .env.local. All vars are NEXT_PUBLIC (client-exposed).

# Backend API base URL
NEXT_PUBLIC_API_URL=http://localhost:3000

# This web app's own public URL
NEXT_PUBLIC_WEB_URL=http://localhost:3001

# CloudFront CDN — public images (profile photos, banners)
NEXT_PUBLIC_CDN_HOST=d1234abcd.cloudfront.net
