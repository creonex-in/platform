PORT=3000

# Neon Postgres — https://neon.tech
DATABASE_URL=postgresql://USER:PASSWORD@HOST/DB?sslmode=require&channel_binding=require
DATABASE_DIRECT_URL=postgresql://USER:PASSWORD@DIRECT_HOST/DB?sslmode=require

# Better Auth
BETTER_AUTH_SECRET=change-me-min-32-chars
BETTER_AUTH_URL=http://localhost:3000

ALLOWED_ORIGINS=http://localhost:3001

# Google OAuth — https://console.cloud.google.com/
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Calendar OAuth token encryption (32-byte key as 64-char hex)
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CALENDAR_TOKEN_ENC_KEY=

# Public base URL of this API (used for OAuth callback URIs)
API_BASE_URL=http://localhost:3000

# Razorpay — https://dashboard.razorpay.com/
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
