PORT=3000

# Redis — required in production for load-balancer-safe rate limiting
# Upstash: rediss://default:<token>@<host>.upstash.io:6379
# Self-hosted: redis://localhost:6379
# Leave blank in dev to fall back to in-memory limiters (single-instance only)
REDIS_URL=

# Neon Postgres — https://neon.tech
DATABASE_URL=postgresql://USER:PASSWORD@HOST/DB?sslmode=require&channel_binding=require
DATABASE_DIRECT_URL=postgresql://USER:PASSWORD@DIRECT_HOST/DB?sslmode=require

# Better Auth
BETTER_AUTH_SECRET=change-me-min-32-chars
BETTER_AUTH_URL=http://localhost:3000

ALLOWED_ORIGINS=http://localhost:3001

# Google OAuth — https://console.cloud.google.com/
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Calendar OAuth token encryption (32-byte key as 64-char hex)
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CALENDAR_TOKEN_ENC_KEY=

# Public base URL of this API (used for OAuth callback URIs)
API_BASE_URL=http://localhost:3000

# Razorpay — https://dashboard.razorpay.com/
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
PLATFORM_FEE_BPS=1000     # basis points — 1000 = 10% platform fee taken from each booking

# Resend (transactional email) — https://resend.com
RESEND_API_KEY=re_...
EMAIL_FROM=Creonex <noreply@creonex.in>

# WATI WhatsApp Business — https://wati.io
# Account SID is the subdomain from your WATI dashboard URL, e.g. "live-mt-12345"
WATI_ACCOUNT_SID=
WATI_API_KEY=

# AWS S3 + CloudFront — see docs/s3-cloudfront-setup.md
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=AKIA...
AWS_SECRET_ACCESS_KEY=
S3_PUBLIC_BUCKET=creonex-public
S3_PRIVATE_BUCKET=creonex-private
CDN_PUBLIC_HOST=d1234abcd.cloudfront.net
PRESIGN_EXPIRY_SECONDS=900
